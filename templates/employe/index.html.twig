{% extends 'base.html.twig' %}

{% block title %}Liste des Employés — SENTECH GRH{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Employés</h2>
    <a href="{{ path('employe_create') }}" class="btn btn-primary">+ Nouvel employé</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="thead-dark">
                <tr>
                    <th>Matricule</th>
                    <th>Nom complet</th>
                    <th>Email</th>
                    <th>Département</th>
                    <th>Poste</th>
                    <th>Contrat</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for employe in pagination %}
                    {% set contrat = employe.contratActif %}
                    <tr>
                        <td>{{ employe.matricule }}</td>
                        <td>{{ employe.nomComplet }}</td>
                        <td>{{ employe.email }}</td>
                        <td>{{ employe.departement ? employe.departement.nom : '—' }}</td>
                        <td>{{ employe.poste ? employe.poste.intitule : '—' }}</td>
                        <td>
                            {% if contrat %}
                                {% if contrat.typeContrat.value == 'CDI' %}
                                    <span class="badge badge-success">CDI</span>
                                {% elseif contrat.typeContrat.value == 'CDD' %}
                                    <span class="badge badge-warning">CDD</span>
                                {% elseif contrat.typeContrat.value == 'Stage' %}
                                    <span class="badge badge-info">Stage</span>
                                {% else %}
                                    <span class="badge badge-secondary">{{ contrat.typeContrat.value }}</span>
                                {% endif %}
                            {% else %}
                                <span class="badge badge-danger">Sans contrat</span>
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ path('employe_details', {id: employe.id}) }}" class="btn btn-sm btn-info">Détails</a>
                            <a href="{{ path('employe_edit', {id: employe.id}) }}" class="btn btn-sm btn-warning">Modifier</a>
                            <a href="{{ path('employe_delete', {id: employe.id}) }}" class="btn btn-sm btn-danger">Supprimer</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">Aucun employé enregistré.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3 d-flex justify-content-center">
    {{ knp_pagination_render(pagination) }}
</div>
{% endblock %}
